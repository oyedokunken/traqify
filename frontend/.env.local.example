# ─── Backend API ──────────────────────────────────────────────────────────────
# Local: http://localhost:5000 | Production (Vercel): https://traqify-api.vercel.app
NEXT_PUBLIC_API_URL=http://localhost:5000

# ─── Site URL ─────────────────────────────────────────────────────────────────
# Local: http://localhost:3000 | Production (Vercel): https://traqify.vercel.app
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ─── Supabase ─────────────────────────────────────────────────────────────────
# Copy from: Supabase → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://[project-ref].supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ─── Paystack ─────────────────────────────────────────────────────────────────
# Copy from: dashboard.paystack.com → Settings → API Keys & Webhooks (public key only)
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=
